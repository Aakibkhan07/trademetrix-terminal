# Trade Metrix API — Environment Variables
# Copy to .env and fill in values. NEVER commit .env.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Security
SECRET_KEY=generate-a-64-char-hex-key
ENCRYPTION_KEY=generate-a-44-char-base64-key-for-fernet
CORS_ORIGINS=http://localhost:3000,https://trademetrix.com
COOKIE_DOMAIN=

# Payments
RAZORPAY_KEY_ID=your-key-id
RAZORPAY_KEY_SECRET=your-key-secret
RAZORPAY_PLAN_MONTHLY=plan_id_here
RAZORPAY_PLAN_QUARTERLY=plan_id_here
RAZORPAY_PLAN_HALFYEARLY=plan_id_here
RAZORPAY_PLAN_YEARLY=plan_id_here
PAYTM_MERCHANT_ID=your-merchant-id
PAYTM_MERCHANT_KEY=your-merchant-key

# AI
GEMINI_API_KEY=your-google-ai-studio-key

# External Services
REDIS_URL=redis://localhost:6379/0

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@trademetrix.tech

# SMS (Fast2SMS)
FAST2SMS_API_KEY=your-fast2sms-api-key

# Twilio (WhatsApp/SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_SMS_FROM=+1234567890

# Sentry
SENTRY_DSN=your-sentry-dsn
SENTRY_ENV=development

# Env Vault
DOTENV_KEY=
ENV=development

# TradingView
TRADINGVIEW_WEBHOOK_SECRET=your-webhook-secret

# Fyers OAuth
FYERS_REDIRECT_URI=https://api.ai.trademetrix.tech/api/v1/brokers/fyers/callback

# Server
REQUEST_TIMEOUT_SECONDS=60
MAX_REQUEST_SIZE_BYTES=102400
LOG_LEVEL=INFO
