# Trade Metrix Web — Environment Variables
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/marketdata/ws

# Beta Intelligence
NEXT_PUBLIC_CLARITY_PROJECT_ID=         # Microsoft Clarity project ID (optional)
NEXT_PUBLIC_SENTRY_DSN=                 # Sentry DSN for frontend error tracking (optional)
NEXT_PUBLIC_APP_VERSION=0.0.0           # Set automatically by scripts/version.sh
NEXT_PUBLIC_APP_ENV=development         # environment name for Sentry
