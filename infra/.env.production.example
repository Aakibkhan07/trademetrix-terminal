# ──────────────────────────────────────────────
# TradeMetrix Terminal — Production Environment
# ──────────────────────────────────────────────
# Copy to .env in both apps/api/ and apps/web/
# Fill all values before deploying.

# ========== Supabase ==========
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>
SUPABASE_ANON_KEY=<anon-key>

# ========== Security ==========
SECRET_KEY=<openssl rand -hex 32>
ENCRYPTION_KEY=<openssl rand -base64 32>
CORS_ORIGINS=https://ai.trademetrix.tech,capacitor://localhost
COOKIE_DOMAIN=.trademetrix.tech

# ========== Redis ==========
# REDIS_URL is derived from REDIS_PASSWORD at container runtime.
# Set REDIS_PASSWORD to a strong random value.
REDIS_PASSWORD=<redis-password>
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ========== AI ==========
GEMINI_API_KEY=<gemini-api-key>

# ========== Payments ==========
RAZORPAY_KEY_ID=<razorpay-key>
RAZORPAY_KEY_SECRET=<razorpay-secret>
PAYTM_MERCHANT_ID=<paytm-mid>
PAYTM_MERCHANT_KEY=<paytm-key>

# ========== Notifications ==========
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=<sendgrid-api-key>
SMTP_FROM=noreply@trademetrix.tech

FAST2SMS_API_KEY=<fast2sms-key>
TWILIO_ACCOUNT_SID=<twilio-sid>
TWILIO_AUTH_TOKEN=<twilio-token>
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_SMS_FROM=+12025551234

# ========== Monitoring ==========
SENTRY_DSN=<sentry-dsn>
SENTRY_ENV=production

# ========== Trading ==========
TRADINGVIEW_WEBHOOK_SECRET=<webhook-secret>
FYERS_REDIRECT_URI=https://api.ai.trademetrix.tech/api/v1/brokers/fyers/callback

# ========== Server ==========
ENV=production
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=60
MAX_REQUEST_SIZE_BYTES=102400
BROKER_REQUEST_TIMEOUT=15
BROKER_CONNECT_TIMEOUT=10

# ========== Frontend Only ==========
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
NEXT_PUBLIC_API_URL=https://api.ai.trademetrix.tech/api/v1
NEXT_PUBLIC_WS_URL=wss://api.ai.trademetrix.tech/api/v1/marketdata/ws
