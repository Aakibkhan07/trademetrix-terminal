{
  "__inputs": [],
  "__requires": [],
  "title": "TradeMetrix — API Overview",
  "uid": "trademetrix-api",
  "schemaVersion": 38,
  "version": 1,
  "timezone": "browser",
  "panels": [
    {
      "title": "Request Rate",
      "type": "graph",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "P99 Latency",
      "type": "graph",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "graph",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m])",
          "legendFormat": "5xx %",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active Connections",
      "type": "graph",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "nginx_connections_active",
          "legendFormat": "active",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Memory Usage",
      "type": "graph",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"api\"}",
          "legendFormat": "api",
          "refId": "A"
        }
      ]
    },
    {
      "title": "CPU Usage",
      "type": "graph",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"api\"}[1m])",
          "legendFormat": "api",
          "refId": "A"
        }
      ]
    }
  ]
}
