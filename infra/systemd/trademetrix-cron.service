[Unit]
Description=TradeMetrix Terminal — Bhavcopy Sync Cron
After=network.target

[Service]
Type=oneshot
User=app
Group=app
WorkingDirectory=/opt/trademetrix/apps/api
EnvironmentFile=/opt/trademetrix/apps/api/.env
ExecStart=/usr/local/bin/python -m scripts.sync_bhavcopy
StandardOutput=journal
StandardError=journal
SyslogIdentifier=trademetrix-cron
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
